# Dependências (ambiente local)
node_modules/
backend/node_modules/
frontend/node_modules/

# Banco de dados
backend/prisma/**/*.db
backend/prisma/**/*.db-journal
backend/prisma/**/*.db-shm
backend/prisma/**/*.db-wal

# Variáveis de ambiente
.env
backend/.env
frontend/.env

# WhatsApp session
.wwebjs_auth/
.wwebjs_cache/

# Uploads (não versionar arquivos de usuários)
uploads/media/*
uploads/rg/*
uploads/temp/*
!uploads/media/.gitkeep
!uploads/rg/.gitkeep
!uploads/temp/.gitkeep

# Build
backend/dist/
frontend/dist/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db
