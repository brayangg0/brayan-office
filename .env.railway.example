# ================================================
# VARIÁVEIS DE AMBIENTE PARA O RAILWAY
# Cole estas variáveis no painel do Railway > Variables
# ================================================

NODE_ENV=production
PORT=3333

# Banco de dados — aponte para o Volume do Railway
# No Railway: crie um Volume com mount path /app/data
DATABASE_URL=file:/app/data/prod.db

# Segurança — troque por uma chave forte e única!
JWT_SECRET=substitua_por_chave_forte_minimo_32_caracteres_aqui

# URL do frontend (gerada pelo Railway após o deploy)
FRONTEND_URL=https://SEU-PROJETO.railway.app

# Chromium instalado via nixpacks no Railway
CHROMIUM_PATH=/usr/bin/chromium

# Sessão do WhatsApp — persiste no Volume do Railway
SESSION_PATH=/app/data/.wwebjs_auth

# Pasta de uploads (mídias) — persiste no Volume do Railway
UPLOADS_PATH=/app/data/uploads
